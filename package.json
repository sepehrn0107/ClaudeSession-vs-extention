{
  "name": "claude-sessions",
  "displayName": "Claude Sessions",
  "description": "Browse your local Claude Code session history",
  "version": "0.2.0",
  "publisher": "sepehrn",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-sessions",
          "title": "Claude Sessions",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claude-sessions": [
        {
          "id": "claudeSessionsTree",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeSessions.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeSessions.openSession",
        "title": "Open Session"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeSessions.refresh",
          "when": "view == claudeSessionsTree",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Claude Sessions",
      "properties": {
        "claudeSessions.workspaceRoot": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the directory whose subdirectories are treated as projects (e.g. /home/user/workspace or C:\\Users\\you\\workspace)."
        },
        "claudeSessions.activeProjectFile": {
          "type": "string",
          "default": "",
          "description": "Optional. Path to a file containing 'active: <name>' \u00e2\u20ac\u201d that project group will be expanded by default."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "vitest": "^2.1.9"
  }
}